# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose in frontend

# ── Redis / Upstash (Bull job queue) ──────────────────────────────────────────
# Local dev:   redis://localhost:6379
# Upstash:     rediss://default:<password>@<host>.upstash.io:6379
#              (use rediss:// with double-s for TLS — required by Upstash)
REDIS_URL=redis://localhost:6379

# ── Browserbase ───────────────────────────────────────────────────────────────
# Found in: app.browserbase.com → Settings
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id
BROWSERBASE_USE_PROXIES=true

# ── Anthropic (Planning Mode AI analysis) ─────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Stripe (optional — leave blank to disable billing) ────────────────────────
# Found in: Stripe dashboard → Developers → API keys / Webhooks
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from: Stripe dashboard → Products → (plan) → Prices
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_AGENCY=price_xxx

# ── Platform Reconciliation (Phase 1 — Connection Plumbing) ──────────────────
# Encryption key for OAuth tokens (separate from CAPI key to limit blast radius)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_CONNECTIONS_ENCRYPTION_KEY=

# Google Ads — same OAuth client used for GA4 + Data Manager (combined consent screen)
# Found in: console.cloud.google.com → APIs & Services → Credentials
# Ensure the Data Manager API scope is enabled for this OAuth client.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Developer token: Google Ads → Tools → Developer token
# Standard Access required for production; Basic Access for dev (15k ops/day limit)
GOOGLE_ADS_DEVELOPER_TOKEN=
# Data Manager API developer token — usually the same as GOOGLE_ADS_DEVELOPER_TOKEN.
# Leave blank to fall back to GOOGLE_ADS_DEVELOPER_TOKEN automatically.
GOOGLE_DMA_DEVELOPER_TOKEN=

# Meta Marketing API
# Found in: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# HMAC secret for OAuth CSRF state parameter
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=

# ── Super admin accounts (full access, no billing required) ───────────────────
# Comma-separated emails. Keep to 2–3 trusted people.
# SUPER_ADMIN_EMAILS=founder@example.com,cto@example.com
SUPER_ADMIN_EMAILS=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# In production this must match the deployed frontend URL exactly (no trailing slash).
# Render sets PORT automatically — do not override PORT in the Render dashboard.
FRONTEND_URL=https://atlas.vimi.digital

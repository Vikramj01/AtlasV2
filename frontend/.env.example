# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API → Project URL / anon key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev:      http://localhost:3001
# Render deploy:  https://atlas-backend.onrender.com  (your Render service URL)
VITE_API_URL=http://localhost:3001

# ── Stripe (optional — leave blank to disable payments UI) ────────────────────
# Found in: Stripe dashboard → Products → Price IDs
VITE_STRIPE_PRICE_PRO=price_xxx
VITE_STRIPE_PRICE_AGENCY=price_xxx
